[configuration]
entry_symbol = "foundation_gameplaytags_init"
compatibility_minimum = 4.6

[libraries]

windows.debug.x86_64   = "res://addons/FoundationGameplayTags/bin/libFoundationGameplayTags.windows.debug.x86_64.dll"
windows.release.x86_64 = "res://addons/FoundationGameplayTags/bin/libFoundationGameplayTags.windows.release.x86_64.dll"

linux.debug.x86_64   = "res://addons/FoundationGameplayTags/bin/libFoundationGameplayTags.linux.debug.x86_64.so"
linux.release.x86_64 = "res://addons/FoundationGameplayTags/bin/libFoundationGameplayTags.linux.release.x86_64.so"

macos.debug.x86_64   = "res://addons/FoundationGameplayTags/bin/libFoundationGameplayTags.macos.debug.x86_64.dylib"
macos.release.x86_64 = "res://addons/FoundationGameplayTags/bin/libFoundationGameplayTags.macos.release.x86_64.dylib"
